# EXAMPLE ONLY — Ascendra realtime server systemd unit.
#
# This is a template. Do NOT deploy until approved. Adjust paths/user to match
# the actual server. Contains NO real secrets — secrets live in the
# EnvironmentFile (see DEPLOYMENT.md).
#
# Install (example):
#   sudo cp ascendra-realtime.service.example /etc/systemd/system/ascendra-realtime.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now ascendra-realtime
#
# This service is SEPARATE from the existing Discord bot service. Do not merge
# them and do not modify the bot's unit.

[Unit]
Description=Ascendra Realtime Server (Socket.IO)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple

# Dedicated unprivileged service account (create it; never run as root).
User=ascendra-realtime
Group=ascendra-realtime

# Release directory and secrets file (env file is chmod 600, NOT in git).
WorkingDirectory=/opt/ascendra-realtime
EnvironmentFile=/etc/ascendra/realtime.env
ExecStart=/usr/bin/node src/server.mjs

Restart=always
RestartSec=5

# ── Hardening ────────────────────────────────────────────────────────────────
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
# The app only needs to write within its own release dir (if at all). Logs go to
# journald via stdout, so this can usually be tightened further.
ReadWritePaths=/opt/ascendra-realtime
# Drop all Linux capabilities — the service binds to a high port (8787) behind
# the reverse proxy, so it needs none.
CapabilityBoundingSet=
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
LockPersonality=true
SystemCallArchitectures=native

# NOTE: MemoryDenyWriteExecute=true is intentionally DISABLED. Node.js/V8's JIT
# allocates writable+executable memory; enabling it crashes the runtime. Leave
# it off unless running Node with the JIT disabled (not recommended).
# MemoryDenyWriteExecute=true

# Optional further tightening (validate before enabling, some may need tuning):
# ProtectKernelTunables=true
# ProtectKernelModules=true
# ProtectControlGroups=true
# RestrictNamespaces=true
# RestrictSUIDSGID=true

[Install]
WantedBy=multi-user.target
