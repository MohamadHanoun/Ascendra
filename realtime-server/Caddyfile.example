# EXAMPLE ONLY — Caddy reverse proxy for the Ascendra realtime server.
#
# Do NOT deploy until approved. Caddy obtains/renews TLS automatically via
# Let's Encrypt, so wss:// works out of the box. reverse_proxy upgrades
# WebSocket connections transparently (no extra config needed for Socket.IO).
#
# Usage (example):
#   sudo cp Caddyfile.example /etc/caddy/Caddyfile   # then edit as needed
#   sudo systemctl reload caddy

realtime.ascendrahub.com {
	encode zstd gzip

	# Forward all traffic (HTTP long-poll + WebSocket upgrade) to the local
	# Node server. Caddy handles the Upgrade/Connection headers automatically.
	reverse_proxy 127.0.0.1:8787

	# Optional: lightweight access logging.
	log {
		output stdout
		format console
	}
}
