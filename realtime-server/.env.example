# Ascendra realtime server — example environment (NAMES ONLY, no real secrets).
# Copy to .env for LOCAL development only. Never commit real values.

# Runtime environment: development | production
NODE_ENV=development

# Port the Node server listens on (reverse proxy forwards to this).
PORT=8787

# Optional bind host. Keep 127.0.0.1 in production (proxy handles public).
HOST=127.0.0.1

# Shared server-to-server secret. MUST match the value configured on Vercel.
# Required for POST /internal/events. Leave empty locally to fail closed.
REALTIME_EVENT_SECRET=

# Client-token verification secret (Batch 1F). MUST match the value configured
# on Vercel (REALTIME_CLIENT_TOKEN_SECRET). Used to verify the short-lived
# tokens browsers present in the Socket.IO handshake to join private/admin rooms.
REALTIME_CLIENT_TOKEN_SECRET=

# Comma-separated list of allowed browser origins for CORS / Socket.IO.
# Example: https://www.ascendrahub.com,https://ascendrahub.com
ALLOWED_ORIGINS=

# Public site URL (informational / future use).
ASCENDRA_SITE_URL=

# Log verbosity: error | warn | info | debug
LOG_LEVEL=info

# ── Hardening (Batch 1E) ──────────────────────────────────────────────────────
# Per-IP rate limit for POST /internal/events. Default 120, clamped 1–6000.
INTERNAL_EVENTS_RATE_LIMIT_PER_MINUTE=120

# Optional: how long a signature+timestamp pair is remembered to block replays.
# Default 120 seconds, clamped 30–600. In-memory, single-process only.
INTERNAL_EVENTS_REPLAY_WINDOW_SECONDS=120
