generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NEW ─────────────────────────────────────────────────────────────────────

model Game {
  id                 String  @id @default(cuid())
  name               String
  slug               String  @unique
  shortName          String?
  description        String?
  iconUrl            String?
  coverImageUrl      String?
  platform           String?
  defaultTeamSize    Int     @default(5)
  defaultSubstitutes Int     @default(0)
  isActive           Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournaments Tournament[]
  teams       Team[]

  integrations       GameIntegration[]
  rankingPointEvents RankingPointEvent[]
}

// ─── UNCHANGED ───────────────────────────────────────────────────────────────

model User {
  id        String  @id @default(cuid())
  discordId String  @unique
  username  String
  avatar    String?
  role      String  @default("Member")

  isGuildMember    Boolean   @default(false)
  lastGuildCheckAt DateTime?
  lastLoginAt      DateTime?

  // FACEIT integration
  faceitPlayerId      String?   @unique
  faceitNickname      String?
  faceitAvatar        String?
  faceitCountry       String?
  faceitUrl           String?
  faceitSkillLevelCs2 Int?
  faceitSteamId64     String?
  faceitLinkedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedTeams      Team[]       @relation("TeamLeader")
  teamMemberships TeamMember[]

  sentTeamInvites     TeamInvite[] @relation("TeamInviteSender")
  receivedTeamInvites TeamInvite[] @relation("TeamInviteReceiver")

  tournamentRegistrations TournamentRegistration[] @relation("TournamentRegisteredBy")

  playerGameAccounts PlayerGameAccount[]
  matchReports       MatchReport[]       @relation("MatchReportSubmitter")
  notifications      Notification[]
  rankingPointEvents RankingPointEvent[]
  matchCheckIns      TournamentMatchCheckIn[]
}

// ─── MODIFIED ────────────────────────────────────────────────────────────────

model Tournament {
  id          String  @id @default(cuid())
  title       String
  description String
  gameId      String?
  seasonId    String?

  // Schedule
  startsAt             DateTime?
  endsAt               DateTime?
  registrationOpensAt  DateTime?
  registrationClosesAt DateTime?

  // Slots & roster
  maxTeams           Int @default(16)
  minTeams           Int @default(2)
  teamSize           Int @default(5)
  substitutesAllowed Int @default(0)

  // Format
  format String @default("single_elimination")
  bestOf Int    @default(1)

  // Info
  prize      String?
  imageUrl   String?
  rules      String?
  region     String?
  platform   String?
  visibility String  @default("public")

  // Status
  status             String    @default("draft")
  registrationStatus String    @default("closed")
  endedAt            DateTime?

  // Discord
  discordAnnouncementChannelId String?
  discordAnnouncementMessageId String?
  discordAnnouncementUrl       String?
  discordAnnouncementSyncedAt  DateTime?
  discordAnnouncementLastError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  game               Game?                    @relation(fields: [gameId], references: [id])
  season             RankingSeason?           @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  registrations      TournamentRegistration[]
  results            TournamentResult[]
  matches            Match[]
  rankingPointEvents RankingPointEvent[]

  tournamentMatches TournamentMatch[]

  @@index([discordAnnouncementMessageId])
  @@index([gameId])
  @@index([seasonId])
  @@index([status])
}

model Team {
  id       String  @id @default(cuid())
  name     String
  gameId   String?
  leaderId String

  status          String    @default("draft")
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  discordRoleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leader User  @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  game   Game? @relation(fields: [gameId], references: [id])

  members            TeamMember[]
  invites            TeamInvite[]
  registrations      TournamentRegistration[]
  results            TournamentResult[]
  rankingPointEvents RankingPointEvent[]
  matchesAsA         Match[]                  @relation("MatchTeamA")
  matchesAsB         Match[]                  @relation("MatchTeamB")
  matchCheckIns      TournamentMatchCheckIn[]

  @@unique([name, leaderId])
  @@index([gameId])
}

// ─── UNCHANGED ───────────────────────────────────────────────────────────────

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamInvite {
  id            String    @id @default(cuid())
  teamId        String
  invitedUserId String
  invitedById   String
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  respondedAt   DateTime?

  team        Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedUser User @relation("TeamInviteReceiver", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User @relation("TeamInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([teamId, invitedUserId])
}

model TournamentRegistration {
  id             String @id @default(cuid())
  tournamentId   String
  teamId         String
  registeredById String

  status          String    @default("registered")
  rejectionReason String?
  approvedAt      DateTime?
  cancelledAt     DateTime?
  reviewedAt      DateTime?

  discordRoleStatus      String    @default("not_needed")
  discordRoleName        String?
  discordRoleId          String?
  discordRoleError       String?
  discordRoleRequestedAt DateTime?
  discordRoleSyncedAt    DateTime?

  discordChannelName String?
  discordChannelId   String?

  snapshotTeamName String?
  snapshotTeamGame String?
  snapshotMembers  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  registeredBy User       @relation("TournamentRegisteredBy", fields: [registeredById], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@index([discordRoleStatus])
}

model TournamentResult {
  id           String   @id @default(cuid())
  tournamentId String
  teamId       String
  placement    Int
  points       Int
  note         String?
  awardedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  snapshotTeamName String?
  snapshotTeamGame String?
  snapshotMembers  Json?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@index([tournamentId])
  @@index([teamId])
}

model RankingSeason {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournaments Tournament[]
  pointEvents RankingPointEvent[]
}

model RankingPointEvent {
  id           String   @id @default(cuid())
  teamId       String?
  userId       String?
  gameId       String?
  tournamentId String?
  matchId      String?
  seasonId     String?
  points       Int
  type         String
  reason       String?
  metadata     Json?
  dedupeKey    String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  team       Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  game       Game?            @relation(fields: [gameId], references: [id], onDelete: SetNull)
  tournament Tournament?      @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  match      TournamentMatch? @relation(fields: [matchId], references: [id], onDelete: SetNull)
  season     RankingSeason?   @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([userId])
  @@index([gameId])
  @@index([tournamentId])
  @@index([matchId])
  @@index([seasonId])
  @@index([type])
  @@index([createdAt])
}

model Match {
  id           String @id @default(cuid())
  tournamentId String
  round        Int
  matchNumber  Int

  teamAId String?
  teamBId String?

  scheduledAt      DateTime?
  status           String    @default("pending")
  bestOf           Int       @default(1)
  scoreA           Int       @default(0)
  scoreB           Int       @default(0)
  winnerTeamId     String?
  reportedById     String?
  confirmedByAdmin Boolean   @default(false)
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamA      Team?      @relation("MatchTeamA", fields: [teamAId], references: [id], onDelete: SetNull)
  teamB      Team?      @relation("MatchTeamB", fields: [teamBId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, round, matchNumber])
  @@index([tournamentId])
  @@index([status])
  @@index([teamAId])
  @@index([teamBId])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String
  important   Boolean  @default(false)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServerSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Rule {
  id        String   @id @default(cuid())
  text      String
  order     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String
  description String
  order       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StaffMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  status    String
  avatarUrl String?
  order     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BotEvent {
  id String @id @default(cuid())

  type   String
  status String @default("queued")

  priority Int @default(0)

  attempts    Int @default(0)
  maxAttempts Int @default(3)

  entityType String?
  entityId   String?

  payload Json
  result  Json?
  error   String?

  lockedAt    DateTime?
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, type])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model RealtimeEvent {
  id String @id @default(cuid())

  type       String
  audience   String  @default("public")
  entityType String?
  entityId   String?

  payload Json

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([audience, createdAt])
  @@index([entityType, entityId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  href      String?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ─── TOURNAMENT ENGINE — PHASE 1 ─────────────────────────────────────────────

enum GameProvider {
  manual
  riot_lol
  riot_valorant
  steam
  steam_dota2
  steam_cs2
  dedicated_server
  third_party
}

enum MatchStatus {
  scheduled
  ready
  room_created
  in_progress
  result_pending
  disputed
  confirmed
  completed
  cancelled
  forfeit
  bye
}

enum MatchGameStatus {
  pending
  in_progress
  completed
  cancelled
}

enum ReportStatus {
  submitted
  confirmed
  rejected
  superseded
}

enum WebhookStatus {
  received
  processing
  processed
  failed
  duplicate
}

enum AuditStatus {
  success
  failure
  retrying
}

model GameIntegration {
  id        String       @id @default(cuid())
  gameId    String
  provider  GameProvider
  enabled   Boolean      @default(false)
  config    Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([gameId])
}

model PlayerGameAccount {
  id          String       @id @default(cuid())
  userId      String
  provider    GameProvider
  externalId  String
  displayName String?
  region      String?
  verifiedAt  DateTime?
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@unique([userId, provider])
  @@index([userId])
}

model TournamentMatch {
  id            String      @id @default(cuid())
  tournamentId  String
  roundNumber   Int
  matchNumber   Int
  status        MatchStatus @default(scheduled)
  teamAId       String?
  teamBId       String?
  winnerTeamId  String?
  bestOf        Int         @default(1)
  nextMatchId   String?
  nextMatchSlot String?
  isBye         Boolean     @default(false)
  scheduledAt        DateTime?
  completedAt        DateTime?
  playerInstructions String?
  version            Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // FACEIT CS2 proof — Phase 3 (never auto-updates official result)
  faceitMatchId            String?   @unique
  faceitMatchUrl           String?
  faceitStatus             String?
  faceitDemoUrl            String?
  faceitMap                String?
  faceitScoreRaw           String?
  faceitFaction1Score      Int?
  faceitFaction2Score      Int?
  faceitWinnerFaceitTeamId String?
  faceitParsedResult       Json?
  faceitSyncedAt           DateTime?
  faceitVerifiedAt         DateTime?

  // FACEIT auto-confirm metadata — Phase 4
  faceitAutoAppliedAt   DateTime?
  faceitAutoApplyMethod String?    // "strict" | "faction_order"

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  nextMatch     TournamentMatch?  @relation("MatchAdvancement", fields: [nextMatchId], references: [id], onDelete: SetNull)
  feederMatches TournamentMatch[] @relation("MatchAdvancement")

  games              TournamentMatchGame[]
  reports            MatchReport[]
  room               GameRoom?
  rankingPointEvents RankingPointEvent[]
  checkIns           TournamentMatchCheckIn[]

  @@unique([tournamentId, roundNumber, matchNumber])
  @@index([tournamentId])
  @@index([status])
}

model TournamentMatchCheckIn {
  id        String   @id @default(cuid())
  matchId   String
  userId    String
  teamId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  team  Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([teamId])
  @@index([userId])
}

model TournamentMatchGame {
  id              String          @id @default(cuid())
  matchId         String
  gameNumber      Int
  status          MatchGameStatus @default(pending)
  teamAScore      Int             @default(0)
  teamBScore      Int             @default(0)
  winnerTeamId    String?
  externalMatchId String?
  externalRoomId  String?
  rawResult       Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  match TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, gameNumber])
  @@index([externalMatchId])
}

model MatchReport {
  id            String       @id @default(cuid())
  matchId       String
  submittedById String
  teamId        String
  winnerTeamId  String
  teamAScore    Int
  teamBScore    Int
  evidenceUrl   String?
  status        ReportStatus @default(submitted)
  note          String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  match       TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  submittedBy User            @relation("MatchReportSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)

  @@index([matchId])
}

model GameRoom {
  id        String       @id @default(cuid())
  matchId   String       @unique
  provider  GameProvider
  roomCode  String?
  joinUrl   String?
  password  String?
  status    String
  metadata  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  match TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

model GameWebhookEvent {
  id             String        @id @default(cuid())
  provider       GameProvider
  externalId     String?
  idempotencyKey String
  payload        Json
  status         WebhookStatus @default(received)
  processedAt    DateTime?
  error          String?
  createdAt      DateTime      @default(now())

  @@unique([provider, idempotencyKey])
  @@index([status])
}

model GameApiAuditLog {
  id        String       @id @default(cuid())
  provider  GameProvider
  action    String
  request   Json?
  response  Json?
  status    AuditStatus
  error     String?
  createdAt DateTime     @default(now())

  @@index([provider, action])
}

// ─── FACEIT WEBHOOK LOGGING — Phase 7 ────────────────────────────────────────

model FaceitWebhookLog {
  id                String    @id @default(cuid())
  eventType         String?
  faceitMatchId     String?
  tournamentMatchId String?
  status            String    // received | processed | skipped | failed | unauthorized
  reason            String?
  httpStatus        Int?
  processedAt       DateTime?
  payload           Json?
  createdAt         DateTime  @default(now())

  @@index([eventType])
  @@index([faceitMatchId])
  @@index([tournamentMatchId])
  @@index([status])
  @@index([createdAt])
}
